                <mxCell id="58" value="Features of button&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Every button has a function.&lt;/div&gt;&lt;div&gt;2. Once a button is selected -&amp;nbsp;&lt;/div&gt;&lt;div&gt;(a) it performs its function&lt;/div&gt;&lt;div&gt;(b) list the buttons underlying it&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="280" y="580" width="265" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="59" value="Classes to be formed -&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. button class&lt;/div&gt;&lt;div&gt;a. function&lt;/div&gt;&lt;div&gt;b. list next layer of buttons&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. Function class&lt;/div&gt;&lt;div&gt;a. Stores the output of functions (and relevant data)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. Special button class&lt;/div&gt;&lt;div&gt;a. Trigger buttons&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="302.5" y="820" width="220" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="61" value="Ultimaate Goal:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Create a tree map.&amp;nbsp;&lt;/div&gt;&lt;div&gt;by selecting the available buttons. in one go you create the button tree&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;execute that created map. in next go you execute the created map&lt;/div&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;" parent="1" vertex="1">
                    <mxGeometry x="-140" y="-140" width="370" height="220" as="geometry"/>
                </mxCell>
